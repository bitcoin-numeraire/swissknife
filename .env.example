RUN_MODE=development

# Database migrations
DATABASE_URL="HERE_YOUR_DATABASE_URL"

# Database
SWISSKNIFE_DATABASE__URL="HERE_YOUR_DATABASE_URL"

# Core Lightning
SWISSKNIFE_LN_PROVIDER="cln_grpc"
SWISSKNIFE_CLN_GRPC_CONFIG__ENDPOINT="https://localhost:11002"
SWISSKNIFE_CLN_GRPC_CONFIG__CERTS_DIR="certs/lightningd"
SWISSKNIFE_CLN_REST_CONFIG__RUNE="HERE_YOUR_RUNE"

# JWT
SWISSKNIFE_JWT__SECRET="HERE_YOUR_JWT_SECRET"
