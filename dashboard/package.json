{
  "name": "swissknife-dashboard",
  "author": "Dario Anongba Varela",
  "version": "0.2.0",
  "email": "dario.varela@numeraire.tech",
  "description": "Numeraire Bitcoin SwissKnife Dashboard",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack -p 8080",
    "start": "next start -p 8080",
    "build": "next build",
    "lint": "eslint \"src/**/*.{js,jsx,ts,tsx}\" \"e2e/**/*.{ts,tsx}\" \"playwright.config.ts\" \"vitest.config.ts\"",
    "lint:fix": "eslint --fix \"src/**/*.{js,jsx,ts,tsx}\" \"e2e/**/*.{ts,tsx}\" \"playwright.config.ts\" \"vitest.config.ts\"",
    "lint:print": "npx eslint --print-config eslint.config.mjs > eslint-show-config.json",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "fm:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx}\"",
    "fm:fix": "prettier --write \"src/**/*.{js,jsx,ts,tsx}\"",
    "fix:all": "npm run lint:fix && npm run fm:fix",
    "clean": "rm -rf node_modules .next out dist build",
    "re:dev": "yarn clean && yarn install && yarn dev",
    "re:build": "yarn clean && yarn install && yarn build",
    "re:build-npm": "npm run clean && npm install && npm run build",
    "tsc:dev": "yarn dev & yarn tsc:watch",
    "tsc:watch": "tsc --noEmit --watch",
    "typecheck": "tsc --noEmit",
    "tsc:print": "npx tsc --showConfig",
    "openapi-ts": "rm -rf src/lib/swissknife && openapi-ts"
  },
  "dependencies": {
    "@auth0/auth0-react": "^2.20.0",
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/public-sans": "^5.2.7",
    "@hookform/resolvers": "^5.4.0",
    "@iconify/react": "^6.0.2",
    "@mui/lab": "^9.0.0-beta.5",
    "@mui/material": "^9.2.0",
    "@mui/material-nextjs": "^9.1.1",
    "@mui/x-data-grid": "^9.8.0",
    "@mui/x-date-pickers": "^9.8.0",
    "@mui/x-tree-view": "^9.8.0",
    "@supabase/supabase-js": "^2.110.0",
    "@yudiel/react-qr-scanner": "^2.6.0",
    "apexcharts": "^5.16.0",
    "autosuggest-highlight": "^3.3.4",
    "bech32": "^2.0.0",
    "dayjs": "^1.11.21",
    "embla-carousel": "^8.6.0",
    "embla-carousel-auto-scroll": "^8.6.0",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "es-toolkit": "^1.49.0",
    "framer-motion": "^12.42.2",
    "i18next": "^26.3.4",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-resources-to-backend": "^1.2.1",
    "jwt-decode": "^4.0.0",
    "light-bolt11-decoder": "^3.2.0",
    "minimal-shared": "^1.1.6",
    "mui-one-time-password-input": "^7.0.0",
    "next": "^16.2.10",
    "nprogress": "^0.2.0",
    "react": "^19.2.7",
    "react-apexcharts": "^2.1.1",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.80.0",
    "react-i18next": "^17.0.8",
    "react-qrcode-logo": "^4.1.0",
    "simplebar-react": "^3.3.2",
    "sonner": "^2.0.7",
    "swr": "^2.4.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@hey-api/openapi-ts": "^0.99.0",
    "@playwright/test": "^1.61.1",
    "@svgr/webpack": "^8.1.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/autosuggest-highlight": "^3.2.3",
    "@types/node": "^24.13.2",
    "@types/nprogress": "^0.2.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/parser": "^8.62.1",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-perfectionist": "^4.15.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^16.5.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  },
  "packageManager": "yarn@4.17.0",
  "engines": {
    "node": ">=24.0.0"
  }
}
