# Core Lightning — integration regtest node.
# Mounted read-only at /etc/cln/config; node data, gRPC certs and the rune live
# in the lightning-dir (/root/.lightning), backed by a Docker named volume.
# The network is set via the LIGHTNINGD_NETWORK env var in docker-compose.
alias=swissknife-itest-cln
log-level=info
bitcoin-rpcconnect=bitcoind
bitcoin-rpcport=18443
bitcoin-rpcuser=regtest
bitcoin-rpcpassword=regtest
bitcoin-retry-timeout=120
bind-addr=0.0.0.0:9736
grpc-host=0.0.0.0
grpc-port=11002
clnrest-host=0.0.0.0
clnrest-port=3010
clnrest-protocol=https
developer
# Poll bitcoind every second so CLN tracks freshly-mined blocks. The default slow
# poll lags the tip under test chain churn, making a concurrent `pay` time out
# "waiting for blockheight". (A dev option; `developer` above enables it.)
dev-bitcoind-poll=1
